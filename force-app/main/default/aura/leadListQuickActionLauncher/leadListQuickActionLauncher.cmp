<aura:component
    implements="flexipage:availableForAllPageTypes,force:appHostable,lightning:isUrlAddressable,lightning:hasPageReference"
    access="global"
>
    <aura:attribute name="pageReference" type="Object"/>

    <lightning:navigation aura:id="navService" />

    <div class="launcher-shell slds-card">
        <div class="launcher-body">
            <lightning:button
                label="리드 생성"
                variant="brand"
                onclick="{!c.handleOpen}"
            />
        </div>
    </div>
</aura:component>