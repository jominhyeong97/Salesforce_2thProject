<apex:page
    applyBodyTag="false"
    applyHtmlTag="false"
    cache="false"
    docType="html-5.0"
    showHeader="false"
    sidebar="false"
    standardController="Account"
    standardStylesheets="false"
>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    />
    <title>사업장 위치</title>

    <style>
        html,
        body {
            background: #ffffff;
            height: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            color: #181818;
            font-family: "Malgun Gothic", "Apple SD Gothic Neo", sans-serif;
        }

        .shell {
            box-sizing: border-box;
            display: grid;
            gap: 10px;
            height: 100%;
            padding: 12px;
        }

        .meta {
            display: grid;
            gap: 4px;
        }

        .eyebrow {
            color: #5c5c5c;
            font-size: 12px;
            margin: 0;
        }

        .title {
            font-size: 16px;
            font-weight: 700;
            margin: 0;
        }

        .address {
            color: #3e3e3c;
            font-size: 13px;
            line-height: 1.5;
            margin: 0;
        }

        .map {
            border: 1px solid #d8dde6;
            border-radius: 12px;
            height: 300px;
            overflow: hidden;
        }

        .empty-state {
            align-items: center;
            border: 1px dashed #c9c7c5;
            border-radius: 12px;
            color: #5c5c5c;
            display: none;
            font-size: 13px;
            height: 300px;
            justify-content: center;
            padding: 20px;
            text-align: center;
        }
    </style>
</head>

<body>
    <div class="shell">
        <div class="meta">
            <p class="eyebrow">Kakao Map</p>
            <p class="title">{!Account.Name}</p>
            <p class="address" id="resolvedAddress"></p>
        </div>

        <div class="map" id="map"></div>
        <div class="empty-state" id="emptyState"></div>
    </div>

    <script>
        //<![CDATA[
        function initializeAccountMap() {
            var billingSegments = [
                "{!JSENCODE(Account.BillingStreet)}",
                "{!JSENCODE(Account.BillingCity)}",
                "{!JSENCODE(Account.BillingState)}",
                "{!JSENCODE(Account.BillingPostalCode)}",
                "{!JSENCODE(Account.BillingCountry)}"
            ];

            var shippingSegments = [
                "{!JSENCODE(Account.ShippingStreet)}",
                "{!JSENCODE(Account.ShippingCity)}",
                "{!JSENCODE(Account.ShippingState)}",
                "{!JSENCODE(Account.ShippingPostalCode)}",
                "{!JSENCODE(Account.ShippingCountry)}"
            ];

            var accountName = "{!JSENCODE(Account.Name)}" || "사업장";

            var billingAddress = billingSegments.filter(Boolean).join(" ").trim();
            var shippingAddress = shippingSegments.filter(Boolean).join(" ").trim();
            var address = billingAddress || shippingAddress;

            var resolvedAddress = document.getElementById("resolvedAddress");
            var emptyState = document.getElementById("emptyState");
            var mapContainer = document.getElementById("map");

            function showEmptyState(message) {
                resolvedAddress.textContent = address || "주소 정보 없음";
                emptyState.textContent = message;
                emptyState.style.display = "flex";
                mapContainer.style.display = "none";
            }

            function showSdkFailure() {
                showEmptyState(
                    "카카오 지도 SDK를 불러오지 못했습니다. Kakao Developers에 현재 페이지 도메인(" +
                        window.location.origin +
                        ")이 JavaScript 키 허용 도메인으로 등록되어 있는지, 그리고 Salesforce CSP Trusted Site에 카카오 지도 도메인이 허용되어 있는지 확인해 주세요."
                );
            }

            if (!address) {
                showEmptyState("계정의 청구지 또는 배송지 주소를 입력하면 사업장 지도가 표시됩니다.");
                return;
            }

            resolvedAddress.textContent = address;

            if (
                window.kakaoAccountMapSdkFailed ||
                typeof kakao === "undefined" ||
                !kakao.maps ||
                !kakao.maps.services
            ) {
                showSdkFailure();
                return;
            }

            var map = new kakao.maps.Map(mapContainer, {
                center: new kakao.maps.LatLng(37.5665, 126.978),
                level: 3
            });

            var geocoder = new kakao.maps.services.Geocoder();

            geocoder.addressSearch(address, function(result, status) {
                if (status !== kakao.maps.services.Status.OK || !result.length) {
                    showEmptyState("입력된 주소로 좌표를 찾지 못했습니다. 주소 형식을 다시 확인해 주세요.");
                    return;
                }

                var coords = new kakao.maps.LatLng(result[0].y, result[0].x);

                var marker = new kakao.maps.Marker({
                    map: map,
                    position: coords
                });

                var infoWindow = new kakao.maps.InfoWindow({
                    content:
                        '<div style="padding:8px 12px;font-size:12px;text-align:center;">' +
                        accountName +
                        "</div>"
                });

                infoWindow.open(map, marker);

                map.setCenter(coords);

                window.setTimeout(function() {
                    map.relayout();
                    map.setCenter(coords);
                }, 0);
            });
        }

        function loadKakaoSdk(onReady) {
            if (window.kakao && kakao.maps && kakao.maps.load) {
                kakao.maps.load(onReady);
                return;
            }

            var existingScript = document.querySelector('script[data-kakao-map-sdk="true"]');

            if (existingScript) {
                existingScript.addEventListener(
                    "load",
                    function() {
                        if (window.kakao && kakao.maps && kakao.maps.load) {
                            kakao.maps.load(onReady);
                        } else {
                            window.kakaoAccountMapSdkFailed = true;
                            initializeAccountMap();
                        }
                    },
                    { once: true }
                );
                return;
            }

            var script = document.createElement("script");
            script.src =
                "https://dapi.kakao.com/v2/maps/sdk.js?appkey=" +
                "{!JSENCODE($Label.Kakao_Map_JavaScript_Key)}" +
                "&libraries=services&autoload=false";
            script.async = true;
            script.dataset.kakaoMapSdk = "true";
            script.onload = function() {
                if (window.kakao && kakao.maps && kakao.maps.load) {
                    kakao.maps.load(onReady);
                } else {
                    window.kakaoAccountMapSdkFailed = true;
                    initializeAccountMap();
                }
            };
            script.onerror = function() {
                window.kakaoAccountMapSdkFailed = true;
                initializeAccountMap();
            };

            document.head.appendChild(script);
        }

        try {
            loadKakaoSdk(initializeAccountMap);
        } catch (error) {
            var resolvedAddress = document.getElementById("resolvedAddress");
            var emptyState = document.getElementById("emptyState");
            var mapContainer = document.getElementById("map");

            resolvedAddress.textContent = resolvedAddress.textContent || "주소 확인 필요";
            emptyState.textContent =
                "지도를 초기화하는 중 오류가 발생했습니다. 브라우저 콘솔에서 상세 오류를 확인해 주세요: " +
                (error && error.message ? error.message : error);
            emptyState.style.display = "flex";
            mapContainer.style.display = "none";
        }
        //]]>
    </script>
</body>
</html>
</apex:page>
